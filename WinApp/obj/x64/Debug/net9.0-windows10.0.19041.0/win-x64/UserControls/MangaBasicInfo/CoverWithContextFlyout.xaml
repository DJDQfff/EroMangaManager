<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.UserControls.MangaBasicInfo.CoverWithContextFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="using:EroMangaManager.WinUI3.Commands"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mangainfo="using:EroMangaManager.WinUI3.UserControls.MangaBasicInfo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    MaxWidth="400"
    MaxHeight="800"
                                           
    mc:Ignorable="d">
    <UserControl.Resources>
        <MenuFlyout x:Key="flyout">
            <!--<MenuFlyoutItem Command="{x:Bind commands:MangaCommands.Instance.OpenManga}" CommandParameter="{x:Bind Source, Mode=OneWay}" />-->
            <MenuFlyoutSubItem x:ConnectionId='2'
                x:Name="openwith"
                Icon="OpenWith"
                                              
                Text="{uid:Strings Uid=OpenWithExternal}" />
            <MenuFlyoutItem x:ConnectionId='3'
                                                                                   
                                                               
                Icon="OpenLocal"
                Text="{uid:Strings Uid=LocateInExplorer}" />
            <MenuFlyoutSubItem x:ConnectionId='4'
                x:Name="moveto"
                Icon="MoveToFolder"
                                      
                Text="{uid:Strings Uid=MoveToOtherFolder}" />

            <MenuFlyoutItem x:ConnectionId='5'
                                                                                   
                                                               
                Text="{uid:Strings Uid=OverviewInformation}" />
            <MenuFlyoutItem x:ConnectionId='6'
                                                                                       
                                                               
                Text="{uid:Strings Uid=RenameFile}" />
            <MenuFlyoutItem x:ConnectionId='7'
                                                                             
                                                                         
                Text="{uid:Strings Uid=SearchSimialr}" />            
            <MenuFlyoutItem x:ConnectionId='8'
                                                                            
                                                               
                Text="{uid:Strings Uid=ExportToPDF}" />

            <MenuFlyoutSeparator />

            <MenuFlyoutItem x:ConnectionId='9'
                                                                                       
                                                               
                Foreground="Red"
                Text="{uid:Strings Uid=DeleteIt}" />
            <!--</MenuFlyoutSubItem>-->
        </MenuFlyout>
    </UserControl.Resources>
    <Image x:ConnectionId='10'
        x:Name="image"
        ContextFlyout="{StaticResource flyout}"
                                       
                                                        />
</UserControl>

