<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.FunctionChildPages.FindSameManga"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="using:EroMangaManager.WinUI3.Commands"
    xmlns:coremodel="using:EroMangaManager.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:functionchildpages="using:EroMangaManager.WinUI3.Views.FunctionChildPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:usercontrols="using:EroMangaManager.WinUI3.UserControls.MangaComplexDisplay"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <ComboBox x:ConnectionId='14' x:Name="combobox" SelectedIndex="0">
                <ComboBoxItem Content="{uid:Strings Uid=Method1}" />
                <ComboBoxItem Content="{uid:Strings Uid=Method2}" />
                <ComboBoxItem Content="{uid:Strings Uid=Method3}" />
                <ComboBoxItem Content="{uid:Strings Uid=Method4}" />
            </ComboBox>
            <Button x:ConnectionId='15'                      Content="{uid:Strings Uid=Start}" />
            <ProgressRing x:ConnectionId='16'                                                      />
        </StackPanel>
        <ListView x:ConnectionId='2'
            x:Name="listView"
            Grid.Row="1"
                                                                     
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate                                         >

                    <Expander x:ConnectionId='4'
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        IsExpanded="True">
                        <Expander.Header>
                            <CommandBar x:ConnectionId='5' VerticalContentAlignment="Center"                        />
                        </Expander.Header>
                        <Expander.Content>
                            <ListView x:ConnectionId='6'                                                 SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate                             >
                                        <Grid x:ConnectionId='8' Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>
                                            <usercontrols:StorageInfo x:ConnectionId='9' Height="200"                  />
                                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                                <Button x:ConnectionId='10'
                                                    HorizontalAlignment="Stretch"
                                                                                                                    
                                                                               
                                                    Content="{uid:Strings Uid=Open}" />
                                                <Button x:ConnectionId='11'
                                                    HorizontalAlignment="Stretch"
                                                                                                                       
                                                                               
                                                    Content="{uid:Strings Uid=OpenFolder}" />
                                                <Button x:ConnectionId='12'
                                                                                                                           
                                                                               
                                                    Content="{uid:Strings Uid=RenameFile}" />
                                                <Button x:ConnectionId='13'
                                                    HorizontalAlignment="Stretch"
                                                                                                                           
                                                                               
                                                    Content="{uid:Strings Uid=DeleteIt}"
                                                    Foreground="Red" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

