<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.MainPageChildPages.FunctionPageShower"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="using:EroMangaManager.WinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Button x:ConnectionId='2'
            x:Name="BackButton"
            x:Load="False"
                                    
            Content="{uid:Strings Uid=SetBack}"
                                                                      />
        <Frame x:ConnectionId='3'
            x:Name="FunctionFrame"
            Grid.Row="1"
            CacheSize="2">
            <Grid Margin="36,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock x:ConnectionId='4'
                    Style="{StaticResource HintTextBlockStyle}"
                    Text="{uid:Strings Uid=NowInitializingMaybeError}"
                                                                                                                                                                     />
                <GridView Grid.Row="1">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Width" Value="150" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <Button x:ConnectionId='5'
                        x:Name="Function_FindSameMangaName"
                                                                                                  
                                            
                        Content="{uid:Strings Uid=FindSameMangaByName}"
                        Style="{StaticResource FunctionShowControl}" />
                    <Button x:ConnectionId='6'
                        x:Name="Function_RemoveRepeatTags"
                        HorizontalAlignment="Stretch"
                                                                                                  
                                            
                        Content="{uid:Strings Uid=RemoveRepeatTags}"
                        Style="{StaticResource FunctionShowControl}" />
                </GridView>
            </Grid>
        </Frame>
    </Grid>
</Page>

