<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.UserControls.RenameMangaByDragTag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mangainfo="using:EroMangaManager.WinUI3.UserControls.MangaBasicInfo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:usercontrols="using:EroMangaManager.WinUI3.UserControls"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="5*" />
            <!--<ColumnDefinition />-->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="2*" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <mangainfo:CoverWithContextFlyout x:ConnectionId='2'
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="0"
                                                 />
        <TextBlock x:ConnectionId='3'
            Grid.Row="0"
            Grid.Column="1"
            Margin="4"
                                                              
            TextWrapping="Wrap" />
        <usercontrols:TagListOrder x:ConnectionId='4'
            x:Name="order"
            Grid.Row="1"
            Grid.Column="1"
            Margin="4" />

        <StackPanel
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Orientation="Vertical"
            Visibility="Visible">
            <TextBox x:ConnectionId='5'
                x:Name="newnameBox"
                Margin="4"
                                                         
                FontSize="16"
                                                          
                TextWrapping="Wrap" />

            <Button x:ConnectionId='6'
                x:Name="renamebutton"
                HorizontalAlignment="Stretch"
                                             
                Content="{uid:Strings Uid=RenameFile}" />
            <Button
                HorizontalAlignment="Stretch"
                Content="{uid:Strings Uid=Remove}"
                Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</UserControl>

