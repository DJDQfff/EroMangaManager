<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.UserControls.RenameMangaByEditString"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mangainfo="using:EroMangaManager.WinUI3.UserControls.MangaBasicInfo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    MaxHeight="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <mangainfo:CoverWithContextFlyout x:ConnectionId='2' x:Name="coverimage"                                      />
        <Grid Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock x:ConnectionId='7'                                               />
                <TextBlock x:ConnectionId='8'
                    x:Name="oldname"
                    VerticalAlignment="Center"
                                                                      
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Vertical">
                <TextBlock x:ConnectionId='3'
                    x:Name="hinttextblock"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="Red"
                    HorizontalTextAlignment="Center" />
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:ConnectionId='5'
                        x:Name="textbox"
                        IsSpellCheckEnabled="False"
                                                         
                        TextWrapping="Wrap" />
                    <TextBlock x:ConnectionId='6'
                        x:Name="aaa"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        x:Load="False"
                                                                
                        TextWrapping="Wrap" />
                </Grid>

                <Button x:ConnectionId='4'
                    x:Name="RenameButton"
                    Grid.Row="4"
                                              
                    Content="{uid:Strings Uid=RenameFile}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

