<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.UserControls.SettingParts.ManageMangaOpenWay3Setting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:setting="using:CommunityToolkit.WinUI.Controls"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings" xmlns:app="using:EroMangaManager.WinUI3"
    mc:Ignorable="d">

    <Grid>


        <setting:SettingsExpander x:ConnectionId='2' x:Name="MangaOpenWay" Header="{uid:Strings Uid=MangaOpenWay}">
            <setting:SettingsExpander.ItemsHeader>
                <!--不知道为什么，只使用selecteditem无法数据绑定，必须通过selectedindex来获取-->
                <!--SelectedIndex="{x:Bind app:App.Current.AppConfig.AppConfig.MangaOpenWay3.WayIndex, Mode=TwoWay}"-->
                <RadioButtons x:ConnectionId='3'                                                                                         
                                                                                                       

                              >
                    <RadioButtons.ItemTemplate>
                        <DataTemplate                      >
                            <RadioButton x:ConnectionId='5'                                                                >
                                <RadioButton.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:ConnectionId='6'
                                                                        
                                                                  
                                            Text="{uid:Strings Uid=Remove}" />
                                    </MenuFlyout>
                                </RadioButton.ContextFlyout>
                            </RadioButton>
                        </DataTemplate>
                    </RadioButtons.ItemTemplate>
                </RadioButtons>
            </setting:SettingsExpander.ItemsHeader>
            <setting:SettingsExpander.ItemsFooter>
                <Button x:ConnectionId='7'
                    HorizontalAlignment="Stretch"
                                        
                    Content="{uid:Strings Uid=AddExe}" />
            </setting:SettingsExpander.ItemsFooter>
        </setting:SettingsExpander>
    </Grid>
</UserControl>

