<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.UserControls.TagListOrder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <DataTemplate x:Key="datatemplate"                      >
            <Border x:ConnectionId='7' VerticalAlignment="Center" Background="{ThemeResource SystemAccentColorLight1}">
                <StackPanel FlowDirection="RightToLeft" Orientation="Horizontal">
                    <Button x:ConnectionId='8' x:Name="RemoveButton"                           >
                        <SymbolIcon Symbol="Remove" />
                    </Button>
                    <TextBlock x:ConnectionId='9'
                        x:Name="textblock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalTextAlignment="Center"
                                        />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="datatemplate2"                      >
            <Border x:ConnectionId='3' VerticalAlignment="Center" Background="{ThemeResource SystemAccentColorDark1}">

                <StackPanel FlowDirection="RightToLeft" Orientation="Horizontal">
                    <Button x:ConnectionId='4' x:Name="AddButton"                        >
                        <SymbolIcon Symbol="Add" />
                    </Button>
                    <TextBlock x:ConnectionId='5'
                        x:Name="textblock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalTextAlignment="Center"
                                        />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  DragItemsCompleted="{x:Bind SetNewName}"  -->
        <ListView x:ConnectionId='10'
            x:Name="ListView1"
            Grid.Row="0"
            VerticalAlignment="Center"
            AllowDrop="True"
            CanDragItems="True"
            CanReorderItems="True"
                                                       
            ItemTemplate="{StaticResource datatemplate}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <ListView x:ConnectionId='11'
            x:Name="ListView2"
            Grid.Row="1"
            MinHeight="12"
            VerticalAlignment="Center"
            ItemTemplate="{StaticResource datatemplate2}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>
    </Grid>
</UserControl>

