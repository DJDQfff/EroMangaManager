<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.MainPageChildPages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="using:EroMangaManager.WinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:vm="using:EroMangaManager.Core.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <StandardUICommand x:ConnectionId='2'
            x:Name="AddFolderCommand"
                                        
            Label="{uid:Strings Uid=AddAFolder}">
            <StandardUICommand.IconSource>
                <SymbolIconSource Symbol="Add" />
            </StandardUICommand.IconSource>
        </StandardUICommand>
        <MenuFlyout x:Key="flyout">
            <MenuFlyoutItem x:ConnectionId='3'
                x:Name="SetAsDefaultBookcaseFolder"
                VerticalAlignment="Center"
                                                        
                Icon="Pin"
                Text="{uid:Strings Uid=SetAsDefaultBookcaseFolder}" />
            <MenuFlyoutItem x:ConnectionId='4'
                x:Name="JumpToBookcaseButton"
                VerticalAlignment="Center"
                                                  
                Icon="Read"
                Text="{uid:Strings Uid=ShowFolderBookcase}" />
            <MenuFlyoutItem x:ConnectionId='5'
                x:Name="OpenFolderItem"
                VerticalAlignment="Center"
                                            
                Icon="Folder"
                Text="{uid:Strings Uid=OpenFolder}" />
            <MenuFlyoutItem x:ConnectionId='6'
                x:Name="xxx"
                x:Load="False"
                                        
                Text="{uid:Strings Uid=LoadSubDirectory}" />
            <MenuFlyoutItem x:ConnectionId='7'
                x:Name="RemoveFolderButton"
                                                
                Icon="Remove"
                Text="{uid:Strings Uid=RemoveFolder}" />
        </MenuFlyout>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="71*" />
            <RowDefinition Height="112*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="357*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  Grid.Row=1 这一块留白  -->
        <Button x:ConnectionId='8'
            x:Name="Button_AddFolder"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
                                                />
        <Grid x:ConnectionId='9'
            x:Name="ControlGrid"
            Grid.Row="2"
            HorizontalAlignment="Center"
            Visibility="Visible">
            <StackPanel x:ConnectionId='18'
                x:Name="StackButton"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                RelativePanel.AlignRightWithPanel="True"
                Visibility="Visible">
                <ToggleSwitch x:ConnectionId='19'
                    x:Name="temp"
                    x:Load="False"
                    Header="{uid:Strings Uid=IsEmptyFolderShow}"
                                                
                    OffContent="{uid:Strings Uid=No}"
                    OnContent="{uid:Strings Uid=Yes}"
                                                   />
            </StackPanel>
        </Grid>
        <TextBlock x:ConnectionId='10'
            x:Name="HintAddFolderTextBlock"
            Grid.Row="3"
            HorizontalAlignment="Center"
            Style="{StaticResource HintTextBlockStyle}"
            Text="{uid:Strings Uid=NoFoldersPleaseAddFirst}"
                                                                                                                                                         />
        <ListView x:ConnectionId='11'
            x:Name="list"
            Grid.Row="3"
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
                                                                                            
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate                            >
                    <Grid x:ConnectionId='14' ContextFlyout="{StaticResource flyout}"                                 >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:ConnectionId='15'
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Foreground="CornflowerBlue"
                            IsIndeterminate="True"
                                                                                                                                  />
                        <TextBlock x:ConnectionId='16'
                            MinWidth="50"
                            VerticalAlignment="Center"
                                                                     
                            TextAlignment="Left" />
                        <TextBlock x:ConnectionId='17'
                            x:Name="folderTextBlock"
                            Grid.Column="1"
                            Width="500"
                            Padding="0,0,4,0"
                            VerticalAlignment="Center"
                            FontWeight="Black"
                                                                     />
                        <Button Grid.Column="3" Flyout="{StaticResource flyout}">
                            <SymbolIcon Symbol="More" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!--  TODO 丑不拉几的  -->
        <TextBlock
            Grid.Row="4"
            Text="错误"
            Visibility="Collapsed" />
        <ListView x:ConnectionId='12'
            Grid.Row="5"
            HorizontalAlignment="Center"
                                                                                              
            Visibility="Collapsed" />
    </Grid>
</Page>

