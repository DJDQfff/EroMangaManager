<Page
    x:Class="EroMangaManager.WinUI3.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:mainpagechild="using:EroMangaManager.WinUI3.Views.MainPageChildPages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Grid>
        <NavigationView x:ConnectionId='2'
            x:Name="MainNavigationView"
            VerticalAlignment="Stretch"
            x:FieldModifier="public"
            FlowDirection="LeftToRight"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
                                                        
            OpenPaneLength="200"
            PaneDisplayMode="Auto">
            <!--<NavigationView.Header>
            进度条，以后优化界面
                <ProgressBar
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Center" VerticalContentAlignment="Center"
                    MinHeight="4"
                    IsIndeterminate="False" />
                <TextBlock
                    Grid.Row="0"
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource HintTextBlockStyle}"
                    Text="{uid:Strings Uid=NowInitializingMaybeError}"
                    Visibility="{x:Bind app:App.Current.GlobalViewModel.IsContentInitializing, Mode=OneWay, Converter={StaticResource controlvisibilityconverter}}" />
            </NavigationView.Header>-->
            <NavigationView.MenuItems>
                <NavigationViewItem x:ConnectionId='3'
                    x:Name="BookcaseItem"
                    Content="{uid:Strings Uid=Bookcase}"
                    Icon="ViewAll"
                    IsSelected="True" />
                <NavigationViewItem x:ConnectionId='4'
                    x:Name="ListItem"
                    Content="{uid:Strings Uid=Library}"
                    Icon="Library" />
                <NavigationViewItem x:ConnectionId='5'
                    x:Name="GlobalSearchPage"
                    Content="{uid:Strings Uid=GlobalSearch}"
                    Icon="Find" />
                <!--  TODO 弄这个的话要搞数据库，还得先把MangaTagEdit的页面调好  -->
                <NavigationViewItem x:ConnectionId='6'
                    x:Name="TagsManagePage"
                    Content="{uid:Strings Uid=Tags}"
                    Icon="Tag" />
                <NavigationViewItem x:ConnectionId='7'
                    x:Name="IrregularFileNames"
                    Content="{uid:Strings Uid=IrregularName}"
                    Icon="Edit" />
                <NavigationViewItem x:ConnectionId='8'
                    x:Name="FindSameMangaByName"
                    Content="{uid:Strings Uid=FindSameMangaByName}"
                    Icon="Copy" />
                <!--<NavigationViewItem
                    x:Name="RemoveRepeatTags"
                    Content="{uid:Strings Uid=RemoveRepeatTags}"
                    Icon="Tag"
                    Visibility="Visible" />-->
                <NavigationViewItem x:ConnectionId='9'
                    x:Name="SeriesMangas"
                    Content="{uid:Strings Uid=SeriesMangas}"
                    Icon="List"
                    Visibility="Collapsed" />
                <NavigationViewItemSeparator />
                <NavigationViewItem x:ConnectionId='10' x:Name="Server" Content="{uid:Strings Uid=Server}" Icon="Remote" />
            </NavigationView.MenuItems>
            <NavigationView.Content>
                <Frame x:ConnectionId='11' x:Name="MainFrame" x:FieldModifier="public" >
                    <mainpagechild:Bookcase/>
                </Frame>
            </NavigationView.Content>
            <!--<NavigationView.Header>
                <ProgressBar  IsIndeterminate="{x:Bind app:App.Current.GlobalViewModel.IsContentInitializing,Mode=OneWay}" />
            </NavigationView.Header>-->
            <NavigationView.PaneFooter>
                <StackPanel
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Orientation="Vertical">
                    <NavigationViewItem x:ConnectionId='12'
                        x:Name="UsageButton"
                        Content="{uid:Strings Uid=Usage}"
                        Icon="Help"
                                                    />
                    <NavigationViewItem x:ConnectionId='13'
                        x:Name="UpdateRecordItem"
                        x:Load="False"
                        Content="{uid:Strings Uid=UpdateRecords}"
                        Icon="ShowResults"
                                                         />
                </StackPanel>
            </NavigationView.PaneFooter>
        </NavigationView>
    </Grid>
</Page>

