<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.SettingPageChildPages.FiltedImagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EroMangaManager.WinUI3.Views.SettingPageChildPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical">
            <ToggleSwitch x:ConnectionId='6'
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Header="{uid:Strings Uid=WhetherOpenFilterImageFunction}"
                                            
                OffContent="{uid:Strings Uid=No}"
                OnContent="{uid:Strings Uid=Yes}"
                                               />
        </StackPanel>
        <GridView x:ConnectionId='2'
            x:Name="GridViewControl"
            Grid.Row="1"
                                                     
            SelectionMode="Multiple">
            <GridView.ItemTemplate>
                <DataTemplate                             >
                    <Image x:ConnectionId='5'
                        Width="136"
                        Height="192"
                                                      />
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        <Button x:ConnectionId='3'
            Grid.Row="2"
            Width="200"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
                                >
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="{uid:Strings Uid=SetBack}" />
                <FontIcon FontFamily="Segoe UI Emoji" Glyph="&#x2714;" />
            </StackPanel>
        </Button>
    </Grid>
</Page>

