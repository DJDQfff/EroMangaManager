<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.MainPageChildPages.IrregularNameSearch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EroMangaManager.WinUI3.Views.MainPageChildPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:EroMangaManager.Core.Models"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:usercontrol="using:EroMangaManager.WinUI3.UserControls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button x:ConnectionId='5'                      Content="{uid:Strings Uid=Start}" />
            <CheckBox x:ConnectionId='6'
                x:Name="checkbox0"
                Content="{uid:Strings Uid=NotCorrectBracketPairs}"
                IsChecked="True" />
            <CheckBox x:ConnectionId='7'
                x:Name="checkbox1"
                Content="{uid:Strings Uid=HaveNoneBrackets}"
                IsChecked="True" />
            <CheckBox x:ConnectionId='8'
                x:Name="checkbox2"
                Content="{uid:Strings Uid=AllInBrackets}"
                IsChecked="True" />
            <CheckBox x:ConnectionId='9'
                x:Name="checkbox3"
                Content="{uid:Strings Uid=RemoveRepeatTags}"
                IsChecked="True" />
            <TextBox x:ConnectionId='10' x:Name="textbox" PlaceholderText="{uid:Strings Uid=WhereContains}" />
        </StackPanel>
        <ListView x:ConnectionId='2' Grid.Row="1"                                          >
            <ListView.ItemTemplate>
                <DataTemplate                         >
                    <usercontrol:RenameMangaByEditString x:ConnectionId='4'
                        Height="320"
                        Margin="4"
                        HorizontalAlignment="Stretch"
                                         />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

