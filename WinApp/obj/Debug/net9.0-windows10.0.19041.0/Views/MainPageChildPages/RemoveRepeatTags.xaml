<Page x:ConnectionId='1'
    x:Class="EroMangaManager.WinUI3.Views.FunctionChildPages.RemoveRepeatTags"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:EroMangaManager.Core.Models"
    xmlns:uid="using:EroMangaManager.WinUI3.Strings"
    xmlns:usercontrol="using:EroMangaManager.WinUI3.UserControls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <CommandBar Grid.Row="0">
            <CommandBar.Content>
                <TextBlock x:ConnectionId='11' VerticalAlignment="Center"                                                />
            </CommandBar.Content>
            <CommandBar.PrimaryCommands>
                <!--<AppBarToggleButton Icon="Switch" x:Name="switchbutton" />-->
            </CommandBar.PrimaryCommands>
        </CommandBar>
        <ListView x:ConnectionId='2'
            x:Name="listview"
            Grid.Row="1"
                                                           
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate                         >
                    <UserControl x:ConnectionId='4'                            >
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="5*" />
                                <!--<ColumnDefinition />-->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition Height="2*" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Image x:ConnectionId='5'
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Grid.Column="0"
                                                            />
                            <TextBlock x:ConnectionId='6'
                                Grid.Row="0"
                                Grid.Column="1"
                                FontSize="16"
                                                                            
                                TextWrapping="Wrap" />
                            <usercontrol:TagListOrder x:ConnectionId='7'
                                x:Name="order"
                                Grid.Row="1"
                                Grid.Column="1"
                                x:Load="False"
                                                      
                                                             />
                            <TextBox x:ConnectionId='8'
                                x:Name="newnameBox"
                                Grid.Row="2"
                                Grid.Column="1"
                                                      
                                FontSize="16"
                                Text="{Binding ElementName=order, Path=NewName, Mode=OneWay}"
                                                                    
                                TextWrapping="Wrap" />
                            <StackPanel
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Orientation="Vertical"
                                Visibility="Collapsed">
                                <Button x:ConnectionId='9'
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                                                 
                                    Content="{uid:Strings Uid=RenameFile}" />
                                <Button x:ConnectionId='10'
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                                        
                                    Content="{uid:Strings Uid=Remove}" />
                            </StackPanel>
                        </Grid>
                    </UserControl>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

